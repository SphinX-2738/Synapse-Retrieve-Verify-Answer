# Synapse — Retrieve. Verify. Answer.
# Copy this file to .env and fill in your actual keys

# LLM Provider (Groq - Free tier)
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace Inference API (embeddings)
# Get your key at: https://huggingface.co/settings/tokens
HF_API_KEY=your_hf_api_key_here

# Embedding mode
# "api" for production (Render), "local" for development
EMBED_MODE=api

# Your deployed app URL (for self-ping keep-alive)
# Local: http://localhost:8000
# Production: https://your-app-name.onrender.com
APP_URL=http://localhost:8000